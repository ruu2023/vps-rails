<%
  apps = [
    { key: :kaikei, name: "会計アプリ", icon: "fa-solid fa-yen-sign", path: kaikei_dashboard_path },
    { key: :reservation, name: "予約カレンダー", icon: "fa-solid fa-calendar-days", path: reservation_events_path }
  ]
  title_class = local_assigns.fetch(:title_class, "text-xl font-semibold text-gray-900")
%>
<div class="relative" data-controller="dropdown" data-action="click@window->dropdown#closeIfOutside">
  <button type="button" data-action="click->dropdown#toggle"
          class="flex items-center gap-1 <%= title_class %>">
    <%= label %>
    <i class="fa-solid fa-chevron-down text-xs text-gray-400"></i>
  </button>

  <div data-dropdown-target="menu"
       class="pointer-events-none absolute left-0 top-full z-20 mt-2 w-48 origin-top-left scale-95 rounded-lg bg-white py-1 opacity-0 shadow-lg ring-1 ring-black/5 transition">
    <% apps.each do |app| %>
      <%= link_to app[:path],
            class: "flex items-center gap-2 px-4 py-2 text-sm #{app[:key] == current ? "font-semibold text-blue-600" : "text-gray-700 hover:bg-gray-50"}" do %>
        <i class="<%= app[:icon] %> w-4 text-center"></i>
        <%= app[:name] %>
        <% if app[:key] == current %>
          <i class="fa-solid fa-check ml-auto text-xs"></i>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>
