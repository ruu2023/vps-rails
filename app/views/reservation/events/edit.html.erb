<%= turbo_frame_tag "modal" do %>
  <div class="fixed inset-0 z-40 flex items-center justify-center bg-black/40 p-4">
    <div class="w-full max-w-md rounded-lg bg-white p-5 shadow-xl">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-gray-900">予定を編集</h2>
        <%= link_to reservation_events_path, data: { turbo_frame: "modal" }, class: "text-gray-400 hover:text-gray-600" do %>
          <i class="fa-solid fa-xmark text-xl"></i>
        <% end %>
      </div>
      <%= render "form", event: @event, url: reservation_event_path(@event), submit_label: "更新する" %>
      <%= button_to "削除する", reservation_event_path(@event), method: :delete,
            class: "mt-4 w-full cursor-pointer rounded-lg bg-red-500 py-2 font-semibold text-white hover:opacity-90",
            form: { data: { turbo_confirm: "この予定を削除しますか?", turbo_frame: "_top" } } %>
    </div>
  </div>
<% end %>
