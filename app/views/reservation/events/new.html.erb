<%= turbo_frame_tag "modal" do %>
  <div class="fixed inset-0 z-40 flex items-center justify-center bg-black/40 p-4">
    <div class="w-full max-w-md rounded-lg bg-white p-5 shadow-xl">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-gray-900">予定を作成</h2>
        <%= link_to reservation_events_path, data: { turbo_frame: "modal" }, class: "text-gray-400 hover:text-gray-600" do %>
          <i class="fa-solid fa-xmark text-xl"></i>
        <% end %>
      </div>
      <%= render "form", event: @event, url: reservation_events_path, submit_label: "作成する" %>
    </div>
  </div>
<% end %>
