<% card_base = "block cursor-pointer rounded-kaikei-control border border-black/10 px-4 py-4 text-center text-sm font-medium text-kaikei-text has-[:checked]:border-kaikei-primary has-[:checked]:bg-kaikei-primary/5 has-[:disabled]:cursor-not-allowed has-[:disabled]:text-kaikei-text-subtle" %>

<h2 class="mx-4 mt-4 text-lg font-semibold text-kaikei-text">データエクスポート</h2>

<%= form_with url: kaikei_exports_path, method: :post, local: true, data: { turbo: false }, class: "contents" do |f| %>
  <section class="mx-4 mt-4 rounded-kaikei-card bg-white p-5 shadow-kaikei-section">
    <h3 class="text-sm font-semibold text-kaikei-text">期間を選択</h3>
    <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div>
        <%= f.label :start_date, "開始日", class: "mb-2 block text-sm text-kaikei-text-muted" %>
        <%= f.date_field :start_date, value: export_start_date, class: "w-full rounded-kaikei-control bg-kaikei-bg px-4 py-3 text-kaikei-text focus:outline-none focus:ring-2 focus:ring-kaikei-primary/20" %>
      </div>
      <div>
        <%= f.label :end_date, "終了日", class: "mb-2 block text-sm text-kaikei-text-muted" %>
        <%= f.date_field :end_date, value: export_end_date, class: "w-full rounded-kaikei-control bg-kaikei-bg px-4 py-3 text-kaikei-text focus:outline-none focus:ring-2 focus:ring-kaikei-primary/20" %>
      </div>
    </div>
  </section>

  <section class="mx-4 mt-4 rounded-kaikei-card bg-white p-5 shadow-kaikei-section">
    <h3 class="text-sm font-semibold text-kaikei-text">エクスポート形式</h3>
    <div class="mt-3 space-y-3">
      <label class="<%= card_base %>">
        <%= f.radio_button :format, "csv", disabled: true, class: "sr-only" %>
        <i class="fa-solid fa-file-csv mb-2 block text-2xl text-kaikei-primary"></i>
        CSV形式（現在開発中）
      </label>
      <label class="<%= card_base %>">
        <%= f.radio_button :format, "excel", checked: true, class: "sr-only" %>
        <i class="fa-solid fa-file-excel mb-2 block text-2xl text-kaikei-primary"></i>
        Excel形式
      </label>
      <label class="<%= card_base %>">
        <%= f.radio_button :format, "pdf", disabled: true, class: "sr-only" %>
        <i class="fa-solid fa-file-pdf mb-2 block text-2xl text-kaikei-primary"></i>
        PDF形式（現在開発中）
      </label>
    </div>
  </section>

  <section class="mx-4 mt-4 rounded-kaikei-card bg-white p-5 shadow-kaikei-section">
    <h3 class="text-sm font-semibold text-kaikei-text">エクスポート項目</h3>
    <div class="mt-3 space-y-3">
      <label class="<%= card_base %>">
        <%= f.radio_button :kind, "transactions", checked: true, class: "sr-only" %>
        取引データ
      </label>
      <label class="<%= card_base %>">
        <%= f.radio_button :kind, "journal", class: "sr-only" %>
        仕訳帳
      </label>
      <label class="<%= card_base %>">
        <%= f.radio_button :kind, "categories", disabled: true, class: "sr-only" %>
        科目設定（現在開発中）
      </label>
    </div>
  </section>

  <div class="mx-4 mt-4 mb-4">
    <%= f.button type: "submit", class: "flex w-full cursor-pointer items-center justify-center gap-2 rounded-kaikei-control bg-kaikei-primary py-3 font-semibold text-white hover:opacity-90" do %>
      <i class="fa-solid fa-download"></i>
      データをエクスポート
    <% end %>
  </div>
<% end %>
