<% input_class = "w-full rounded-kaikei-control bg-kaikei-bg px-4 py-3 text-kaikei-text focus:outline-none focus:ring-2 focus:ring-kaikei-primary/20" %>

<h2 class="mx-4 mt-4 text-lg font-semibold text-kaikei-text">相手方管理</h2>

<section class="mx-4 mt-4 rounded-kaikei-card bg-white p-5 shadow-kaikei-section">
  <h3 class="text-base font-semibold text-kaikei-text">新しい相手方を追加</h3>

  <%= form_with model: @new_payment_method, scope: :kaikei_payment_method, url: kaikei_payment_methods_path, local: true, class: "mt-4 space-y-4" do |f| %>
    <div>
      <%= f.label :name, "相手方名", class: "mb-2 block text-sm font-medium text-kaikei-text" %>
      <%= f.text_field :name, placeholder: "例: 現金、クレジットカードA", class: input_class %>
    </div>
    <div>
      <%= f.label :type, "区分", class: "mb-2 block text-sm font-medium text-kaikei-text" %>
      <%= f.select :type, [ [ "支出", "expense" ], [ "収入", "income" ] ], {}, class: input_class %>
    </div>
    <%= f.button type: "submit", class: "flex w-full cursor-pointer items-center justify-center gap-2 rounded-kaikei-control bg-kaikei-primary py-3 font-semibold text-white hover:opacity-90" do %>
      <i class="fa-solid fa-plus"></i> 追加
    <% end %>
  <% end %>
</section>

<section class="mx-4 mt-4">
  <h3 class="border-b border-black/10 pb-2 text-sm font-semibold text-kaikei-text">収入の受取方法</h3>
  <ul class="mt-3 space-y-2">
    <% if @income_payment_methods.empty? %>
      <li class="py-2 text-sm text-kaikei-text-subtle">登録されている収入の受取方法はありません。</li>
    <% end %>
    <% @income_payment_methods.each do |payment_method| %>
      <%= render "payment_method_row", payment_method: payment_method %>
    <% end %>
  </ul>
</section>

<section class="mx-4 mt-4 mb-4">
  <h3 class="border-b border-black/10 pb-2 text-sm font-semibold text-kaikei-text">支出の支払方法</h3>
  <ul class="mt-3 space-y-2">
    <% if @expense_payment_methods.empty? %>
      <li class="py-2 text-sm text-kaikei-text-subtle">登録されている支出の支払方法はありません。</li>
    <% end %>
    <% @expense_payment_methods.each do |payment_method| %>
      <%= render "payment_method_row", payment_method: payment_method %>
    <% end %>
  </ul>
</section>
