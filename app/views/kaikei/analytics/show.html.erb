<% content_for :kaikei_header do %>
  <h1 class="text-xl font-semibold text-kaikei-text">取引分析</h1>
<% end %>

<section class="mx-4 mt-4 rounded-kaikei-card bg-white p-5 shadow-kaikei-section">
  <%= form_with url: kaikei_analytics_path, method: :get, local: true, class: "flex flex-wrap items-center gap-2" do %>
    <%= hidden_field_tag :type, @type %>
    <%= hidden_field_tag :category_id, @category_id %>
    <%= date_field_tag :start_date, @start_date, class: "rounded-kaikei-control bg-kaikei-bg px-3 py-2 text-sm text-kaikei-text focus:outline-none focus:ring-2 focus:ring-kaikei-primary/20" %>
    <span class="text-kaikei-text-subtle">〜</span>
    <%= date_field_tag :end_date, @end_date, class: "rounded-kaikei-control bg-kaikei-bg px-3 py-2 text-sm text-kaikei-text focus:outline-none focus:ring-2 focus:ring-kaikei-primary/20" %>
    <%= submit_tag "適用", class: "ml-auto cursor-pointer rounded-kaikei-control bg-kaikei-primary px-5 py-2 text-sm font-semibold text-white hover:opacity-90" %>
  <% end %>
</section>

<section class="mx-4 mt-4 overflow-hidden rounded-kaikei-card bg-white shadow-kaikei-card">
  <%= render "summary_card", icon: "fa-arrow-down", icon_bg_class: "bg-kaikei-income/10", icon_color_class: "text-kaikei-income",
        label: "収入", amount: "¥#{number_with_delimiter(@income_total)}" %>
  <%= render "summary_card", icon: "fa-arrow-up", icon_bg_class: "bg-kaikei-expense/10", icon_color_class: "text-kaikei-expense",
        label: "支出", amount: "¥#{number_with_delimiter(@expense_total)}" %>
  <%= render "summary_card", icon: "fa-coins", icon_bg_class: "bg-kaikei-primary/10", icon_color_class: "text-kaikei-primary",
        label: "収支", amount: "#{@balance >= 0 ? "+" : "-"}¥#{number_with_delimiter(@balance.abs)}" %>
</section>

<section class="mx-4 mt-4 rounded-kaikei-card bg-white p-5 shadow-kaikei-section"
  data-controller="kaikei--analytics-chart"
  data-kaikei--analytics-chart-monthly-labels-value="<%= @monthly_series.map { |m| m[:label] }.to_json %>"
  data-kaikei--analytics-chart-monthly-income-value="<%= @monthly_series.map { |m| m[:income] }.to_json %>"
  data-kaikei--analytics-chart-monthly-expense-value="<%= @monthly_series.map { |m| m[:expense] }.to_json %>"
  data-kaikei--analytics-chart-category-labels-value="<%= @category_series.map { |c| c[:name] }.to_json %>"
  data-kaikei--analytics-chart-category-amounts-value="<%= @category_series.map { |c| c[:amount] }.to_json %>"
>
  <h2 class="text-base font-semibold text-kaikei-text">収支推移</h2>
  <div class="mt-4 h-[220px] md:h-[300px]">
    <canvas data-kaikei--analytics-chart-target="canvas"></canvas>
  </div>
  <div class="mt-4 flex justify-center gap-2">
    <button type="button" data-mode="monthly" data-action="click->kaikei--analytics-chart#switchTab"
      data-kaikei--analytics-chart-target="tab"
      class="rounded-full bg-kaikei-primary px-4 py-2 text-sm font-medium text-white">月次推移</button>
    <button type="button" data-mode="category" data-action="click->kaikei--analytics-chart#switchTab"
      data-kaikei--analytics-chart-target="tab"
      class="rounded-full px-4 py-2 text-sm font-medium text-kaikei-text-subtle">科目別集計</button>
  </div>
</section>

<section class="mx-4 mt-4 rounded-kaikei-card bg-white shadow-kaikei-section">
  <div class="flex flex-wrap items-center justify-between gap-2 px-5 pt-5">
    <h2 class="text-base font-semibold text-kaikei-text">取引明細</h2>
    <div class="flex gap-2">
      <%= form_with url: kaikei_analytics_path, method: :get, local: true, data: { controller: "kaikei--auto-submit" } do %>
        <%= hidden_field_tag :start_date, @start_date %>
        <%= hidden_field_tag :end_date, @end_date %>
        <%= hidden_field_tag :category_id, @category_id %>
        <%= select_tag :type, options_for_select([ [ "すべて", "" ], [ "収入", "income" ], [ "支出", "expense" ] ], @type),
              data: { action: "change->kaikei--auto-submit#submit" },
              class: "rounded-kaikei-control bg-kaikei-bg px-3 py-2 text-sm text-kaikei-text focus:outline-none focus:ring-2 focus:ring-kaikei-primary/20" %>
      <% end %>
      <%= form_with url: kaikei_analytics_path, method: :get, local: true, data: { controller: "kaikei--auto-submit" } do %>
        <%= hidden_field_tag :start_date, @start_date %>
        <%= hidden_field_tag :end_date, @end_date %>
        <%= hidden_field_tag :type, @type %>
        <%= select_tag :category_id,
              options_for_select([ [ "全科目", "" ] ] + @categories.map { |c| [ c.name, c.id ] }, @category_id),
              data: { action: "change->kaikei--auto-submit#submit" },
              class: "rounded-kaikei-control bg-kaikei-bg px-3 py-2 text-sm text-kaikei-text focus:outline-none focus:ring-2 focus:ring-kaikei-primary/20" %>
      <% end %>
    </div>
  </div>

  <% if @transactions.any? %>
    <ul class="mt-3">
      <% @transactions.each do |transaction| %>
        <%= render "transaction_row", transaction: transaction %>
      <% end %>
    </ul>

    <% total_pages = (@total_count / Kaikei::AnalyticsController::PER_PAGE.to_f).ceil %>
    <% if total_pages > 1 %>
      <div class="flex items-center justify-center gap-4 px-5 py-4 text-sm text-kaikei-text-muted">
        <%= link_to "前へ", kaikei_analytics_path(start_date: @start_date, end_date: @end_date, type: @type, category_id: @category_id, page: @page - 1),
              class: @page <= 1 ? "pointer-events-none opacity-30" : "text-kaikei-primary" %>
        <span><%= @page %> / <%= total_pages %></span>
        <%= link_to "次へ", kaikei_analytics_path(start_date: @start_date, end_date: @end_date, type: @type, category_id: @category_id, page: @page + 1),
              class: @page >= total_pages ? "pointer-events-none opacity-30" : "text-kaikei-primary" %>
      </div>
    <% end %>
  <% else %>
    <p class="px-5 py-8 text-center text-sm text-kaikei-text-subtle">指定された期間に取引データがありません</p>
  <% end %>
</section>
