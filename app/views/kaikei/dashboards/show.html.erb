<section class="mx-4 mt-4 rounded-kaikei-card bg-gradient-to-br from-kaikei-primary to-kaikei-primary-dark p-5 text-white shadow-kaikei-card">
  <div class="flex items-center justify-between">
    <h2 class="text-base font-semibold">今月の収支</h2>
    <span class="text-sm text-white/80"><%= Date.current.strftime("%Y年%-m月") %></span>
  </div>

  <div class="mt-4 flex divide-x divide-white/25">
    <div class="flex-1 pr-4 text-center">
      <p class="text-sm text-white/80">今月</p>
      <p class="mt-1 text-2xl">
        <%= render "kaikei/shared/amount", amount: @current_balance, positive: @current_balance >= 0, variant: :balance %>
      </p>
    </div>
    <div class="flex-1 pl-4 text-center">
      <p class="text-sm text-white/80">前月比</p>
      <p class="mt-1 text-2xl <%= @balance_change_rate >= 0 ? "text-kaikei-balance-positive" : "text-kaikei-balance-negative" %>">
        <%= @balance_change_rate >= 0 ? "↑" : "↓" %>
        <%= @balance_change_rate >= 0 ? "+" : "" %><%= @balance_change_rate %>%
      </p>
    </div>
  </div>

  <div class="mt-4 flex items-center justify-between border-t border-white/20 pt-3 text-sm text-white/90">
    <span>今月の収入 <%= render "kaikei/shared/amount", amount: @current_income, positive: true, variant: :balance %></span>
    <span>今月の支出 <%= render "kaikei/shared/amount", amount: @current_expense, positive: false, variant: :balance %></span>
  </div>
</section>

<section class="mx-4 mt-4 grid grid-cols-4 gap-2 rounded-kaikei-card bg-white p-4 shadow-kaikei-section">
  <%= link_to new_kaikei_transaction_path(type: "income"), class: "flex flex-col items-center gap-1 text-kaikei-text-muted" do %>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6 text-kaikei-primary">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
    </svg>
    <span class="text-xs">収入登録</span>
  <% end %>
  <%= link_to new_kaikei_transaction_path(type: "expense"), class: "flex flex-col items-center gap-1 text-kaikei-text-muted" do %>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6 text-kaikei-primary">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12h-15" />
    </svg>
    <span class="text-xs">支出登録</span>
  <% end %>
  <%= link_to kaikei_settings_path(tab: "export"), class: "flex flex-col items-center gap-1 text-kaikei-text-muted" do %>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6 text-kaikei-primary">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m5.231 13.481L15 17.25m-1.519-1.519L12 17.25m1.481-1.519L12 14.25m1.481 1.481L15 14.25M8.25 21h7.5a2.25 2.25 0 002.25-2.25V11.25a4.5 4.5 0 00-4.5-4.5H8.25a4.5 4.5 0 00-4.5 4.5v7.5A2.25 2.25 0 006 21z" />
    </svg>
    <span class="text-xs">CSV出力</span>
  <% end %>
  <%= link_to kaikei_analytics_path, class: "flex flex-col items-center gap-1 text-kaikei-text-muted" do %>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6 text-kaikei-primary">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 107.5 7.5h-7.5V6z" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0013.5 3v7.5z" />
    </svg>
    <span class="text-xs">レポート</span>
  <% end %>
</section>

<section class="mx-4 mt-4 rounded-kaikei-card bg-white p-5 shadow-kaikei-section">
  <h2 class="text-base font-semibold text-kaikei-text">収支概要</h2>
  <canvas
    class="mt-4 h-[200px] w-full md:h-[250px]"
    data-controller="kaikei--chart"
    data-kaikei--chart-labels-value="<%= @monthly_series.map { |m| m[:label] }.to_json %>"
    data-kaikei--chart-income-value="<%= @monthly_series.map { |m| m[:income] }.to_json %>"
    data-kaikei--chart-expense-value="<%= @monthly_series.map { |m| m[:expense] }.to_json %>"
  ></canvas>
</section>

<section class="mx-4 mt-4 rounded-kaikei-card bg-white shadow-kaikei-section">
  <div class="flex items-center justify-between px-5 pt-5">
    <h2 class="text-base font-semibold text-kaikei-text">最近の取引</h2>
    <%= link_to "すべて表示", kaikei_analytics_path, class: "text-sm text-kaikei-primary" %>
  </div>
  <ul class="mt-3">
    <% @recent_transactions.each do |transaction| %>
      <%= render "kaikei/shared/transaction_item", transaction: transaction %>
    <% end %>
  </ul>
</section>

<section class="mx-4 mt-4 rounded-kaikei-card bg-white p-5 shadow-kaikei-section">
  <h2 class="text-base font-semibold text-kaikei-text">今月の予算</h2>
  <ul class="mt-3 space-y-4">
    <% @budgets.each do |budget| %>
      <%
        bar_color_class = case budget.warning_level
        when "danger" then "bg-kaikei-expense"
        when "warning" then "bg-kaikei-warning"
        else "bg-kaikei-primary"
        end
      %>
      <li>
        <div class="flex items-center justify-between text-sm">
          <span class="font-medium text-kaikei-text"><%= budget.category.name %></span>
          <span class="text-kaikei-text-muted">
            &yen;<%= number_with_delimiter(budget.actual_spent) %> / &yen;<%= number_with_delimiter(budget.amount) %>
            (<%= budget.progress_percentage %>%)
          </span>
        </div>
        <div class="mt-2 h-2 w-full rounded-kaikei-control bg-black/5">
          <div class="h-2 rounded-kaikei-control <%= bar_color_class %>" style="width: <%= [ budget.progress_percentage, 100 ].min %>%"></div>
        </div>
      </li>
    <% end %>
  </ul>
</section>
